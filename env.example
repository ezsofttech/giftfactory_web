# =============================================================================
# Local development — copy to .env.local
# =============================================================================

APP_ENV=development
NODE_ENV=development

# API (giftfactory_api) — include /api/v1 for this app
NEXT_PUBLIC_API_BASE_URL=http://localhost:9873/api/v1
NEXT_PUBLIC_API_URL=http://localhost:9873/api/v1

# This app (storefront URL)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Payments (client-side)
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxx

# =============================================================================
# Production build (Docker / GitHub Actions — build-time only)
# =============================================================================
# NEXT_PUBLIC_API_BASE_URL=https://api.ezzme.com/api/v1
# NEXT_PUBLIC_APP_URL=https://giftfactory.ezzme.com
# NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_xxxxxxxx
# APP_ENV=production

# =============================================================================
# Development build (Docker image tag: dev-latest)
# =============================================================================
# NEXT_PUBLIC_API_BASE_URL=https://dev-api.ezzme.com/api/v1
# NEXT_PUBLIC_APP_URL=https://dev-giftfactory.ezzme.com
# APP_ENV=development
